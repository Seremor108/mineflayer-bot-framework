        "exclude": [
          "rotten_flesh",
          "poisonous_potato",
          "spider_eye",
          "pufferfish",
          "chorus_fruit",
          "golden_apple",
          "enchanted_golden_apple"
        ]
      },
      "animalInteractions": {
        "enabled": false,
        "checkIntervalMs": 1500,
        "searchRadius": 10,
        "shearSheep": true,
        "milkCows": true,
        "sheepCooldownMs": 300000,
        "cowCooldownMs": 60000,
        "interactionDelayMs": 300,
        "priority": -35
